@server_HostAddress = http://localhost:5040

### Render: open this SSE stream and wait for Viewer answer/ICE
GET {{server_HostAddress}}/api/signaling/render/events
Accept: text/event-stream

### Render: send an offer; a new offer clears events from the previous negotiation
POST {{server_HostAddress}}/api/signaling/render/offer
Content-Type: application/json

{
  "sdp": "v=0\r\no=render 1 1 IN IP4 127.0.0.1\r\ns=mock-offer\r\nt=0 0"
}

### Render: send ICE; Viewer receives it from the Viewer SSE stream
POST {{server_HostAddress}}/api/signaling/render/ice
Content-Type: application/json

{
  "candidate": "candidate:render-1 1 udp 2122260223 192.0.2.1 50000 typ host"
}

### Viewer: open this SSE stream and wait for Render offer/ICE
GET {{server_HostAddress}}/api/signaling/viewer/events
Accept: text/event-stream

### Viewer: send an answer; Render receives it from the Render SSE stream
POST {{server_HostAddress}}/api/signaling/viewer/answer
Content-Type: application/json

{
  "sdp": "v=0\r\no=viewer 1 1 IN IP4 127.0.0.1\r\ns=mock-answer\r\nt=0 0"
}

### Viewer: send ICE; Render receives it from the Render SSE stream
POST {{server_HostAddress}}/api/signaling/viewer/ice
Content-Type: application/json

{
  "candidate": "candidate:viewer-1 1 udp 2122260223 192.0.2.2 50001 typ host"
}
